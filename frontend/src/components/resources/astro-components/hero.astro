---
import { APP_CONTENT } from "@/config/Content";
import cn from "src/utils/cn";
import HeroBgVector from "@/components/shared/astro-components/hero-bg-vector.astro";
---

<HeroBgVector
  wrapperClassName={cn(
    "w-full gap-12 bg-[position:-60%_78%] xl:bg-[position:-60%_98%] bg-no-repeat",
    "bg-[url('../assets/background/sm_resources_vector.svg')]",
    "md:bg-[url('../assets/background/resources_vector.svg')]",
  )}
  contentClassName="h-[20rem] md:h-[30rem]"
>
  <div
    class="w-full space-y-4 bg-contain px-6 text-center md:w-[36rem]"
    id="box"
  >
    <h1 class="text-grey-300 text-2xl font-semibold sm:text-4xl">
      {APP_CONTENT.RESOURCES_PAGE.Hero.title}
    </h1>
    <p class="text-grey-100 text-lg">
      {APP_CONTENT.RESOURCES_PAGE.Hero.description}
    </p>
  </div>
</HeroBgVector>

<script>
  import gsap from "@/utils/gsap";

  const box = document.getElementById("box");

  gsap.from(box, {
    opacity: 0,
    y: 70,
    duration: 1,
    ease: "power2.out", // smooth deceleration, no bounce
    scrollTrigger: {
      trigger: box,
      start: "top 60%",
      toggleActions: "play none none reverse",
    },
  });
</script>

---
import VideoDialog from "@/components/shared/react-components/VideoDialog";
import { APP_CONTENT } from "@/config/Content";
---

<section
  class="bg-grey-500 relative flex h-[30rem] w-full flex-col items-center justify-center px-4 sm:px-6 md:h-[45rem] md:px-8 lg:h-[65.5rem] lg:px-10 xl:px-0"
>
  <div class="relative flex w-full items-center justify-center">
    <VideoDialog client:load id="video" />
  </div>
  <div
    class="flex h-full w-full flex-col items-center justify-end pb-[3.1rem] sm:pb-[5.56rem]"
    id="about"
  >
    <div
      class="text-surface-20 flex max-w-[49.125rem] flex-col items-center justify-center space-y-4 text-center"
    >
      <h2 class="text-xl font-semibold sm:text-4xl">
        {APP_CONTENT.HOME_PAGE.AboutOSM.title}
      </h2>
      <p class="px-4 text-sm font-normal md:px-0 md:text-xl">
        {APP_CONTENT.HOME_PAGE.AboutOSM.description}
      </p>
    </div>
  </div>
  <div
    class="absolute inset-0 bg-[url('../assets/background/about_osm_vector.svg')] bg-cover bg-no-repeat lg:top-5"
  >
  </div>
</section>
